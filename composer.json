{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "velolia/velolia",
    "type": "project",
    "description": "The skeleton web php application",
    "keywords": ["velolia", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "velolia/framework": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}