{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "velolia/velolia",
    "description": "Velolia Web Application",
    "type": "project",
    "keywords": ["velolia", "framework"],
    "license": "MIT",
    "authors": [
        {
            "name": "Edy Purwanto",
            "email": "eddyee99@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "velolia/framework": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php velo key:generate"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
